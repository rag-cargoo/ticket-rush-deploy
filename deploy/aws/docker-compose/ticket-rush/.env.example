AWS_REGION=ap-northeast-2
ECR_REGISTRY=000000000000.dkr.ecr.ap-northeast-2.amazonaws.com

BACKEND_IMAGE_REPO=ticketrush/backend
BACKEND_IMAGE_TAG=latest

FRONTEND_IMAGE_REPO=ticketrush/frontend
FRONTEND_IMAGE_TAG=latest

APP_DOMAIN=goopang.shop
APP_SEED_KPOP20_ENABLED=true
APP_SEED_KPOP20_MARKER_KEY=kpop20_seed_marker_v1

# Backend CORS / OAuth runtime env (required for social login on deployed domain)
FRONTEND_ALLOWED_ORIGINS=https://goopang.shop,https://www.goopang.shop,http://localhost:8080,http://127.0.0.1:8080
U1_CALLBACK_URL=https://goopang.shop/ux/u1/callback.html

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://goopang.shop/login/oauth2/code/kakao

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=https://goopang.shop/login/oauth2/code/naver
NAVER_SERVICE_URL=https://goopang.shop
